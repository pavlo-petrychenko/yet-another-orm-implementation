digraph ar_vs_repo {
  rankdir=TB;
  bgcolor="white";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, margin="0.16,0.10", color="#333333"];
  edge [color="#666666", arrowsize=0.7, fontname="Helvetica", fontsize=9];

  subgraph cluster_ar {
    label="Active Record — фасад";
    fontname="Helvetica"; fontsize=11; style="rounded,dashed"; color="#3a6fb3"; labeljust="l";

    ar_call [label="User.find({ where: { … } })",         fillcolor="#e7f0ff"];
    ar_stat [label="BaseModel.find (static)",             fillcolor="#dde7f7"];
    ar_get  [label="getRepoFor(User)\n— resolveDataSource(cls)\n— ambientEntityManagerFor(ds)", fillcolor="#dde7f7"];
  }

  subgraph cluster_repo {
    label="Repository — фасад";
    fontname="Helvetica"; fontsize=11; style="rounded,dashed"; color="#7a4ea3"; labeljust="l";

    repo_call [label="ds.getRepository(User).find({ … })",     fillcolor="#f3e8fd"];
    ds_get    [label="DataSource.getRepository\n(кеш + repositoryRegistry)", fillcolor="#e8d4f5"];
  }

  core [label="Repository<User>.find(args)", fillcolor="#fff7d6", color="#a87000"];

  resolve [label="Repository.resolveDriver()\ntxDriver?  →  ambientTxFor(ds)?  →  ds.getDriver()", fillcolor="#fde7ef", color="#9b3a64"];

  driver [label="Driver.query(ast: Query)", fillcolor="#eef7e8", color="#3f7a3f"];

  ar_call   -> ar_stat;
  ar_stat   -> ar_get;
  ar_get    -> core   [label="repo.find(args)"];

  repo_call -> ds_get;
  ds_get    -> core   [label="repo.find(args)"];

  core    -> resolve;
  resolve -> driver;
}
