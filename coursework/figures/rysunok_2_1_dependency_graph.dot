digraph YAOI {
  rankdir=TB;
  bgcolor="white";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11, margin="0.18,0.10", color="#333333"];
  edge [fontname="Helvetica", fontsize=9, color="#555555", arrowsize=0.7];

  // Layer 1 — IR (AST + builders)
  subgraph cluster_ir {
    label="Шар проміжного подання (IR)";
    fontname="Helvetica"; fontsize=10; style="rounded,dashed"; color="#999999"; labeljust="l";
    qb  [label="query-builder",  fillcolor="#e7f0ff"];
    sb  [label="schema-builder", fillcolor="#e7f0ff"];
  }

  // Layer 2 — registry
  subgraph cluster_reg {
    label="Шар реєстру метаданих";
    fontname="Helvetica"; fontsize=10; style="rounded,dashed"; color="#999999"; labeljust="l";
    md  [label="metadata",    fillcolor="#eef7e8"];
    dec [label="decorators",  fillcolor="#eef7e8"];
  }

  // Layer 3 — drivers
  subgraph cluster_drv {
    label="Шар драйверів і діалектів";
    fontname="Helvetica"; fontsize=10; style="rounded,dashed"; color="#999999"; labeljust="l";
    drv [label="drivers", fillcolor="#fff3e0"];
  }

  // Layer 4 — model
  subgraph cluster_model {
    label="Шар моделі";
    fontname="Helvetica"; fontsize=10; style="rounded,dashed"; color="#999999"; labeljust="l";
    mdl [label="model", fillcolor="#fde7ef"];
  }

  // Layer 5 — schema evolution / entrypoint
  subgraph cluster_evo {
    label="Шар еволюції схеми та CLI";
    fontname="Helvetica"; fontsize=10; style="rounded,dashed"; color="#999999"; labeljust="l";
    mig [label="migrations", fillcolor="#f3e8fd"];
    cli [label="cli",        fillcolor="#f3e8fd"];
  }

  // Runtime (value) edges — solid
  sb  -> qb;
  md  -> qb;
  drv -> qb;
  dec -> md;
  dec -> mdl;
  mdl -> drv;
  mdl -> md;
  mdl -> qb;
  mig -> drv;
  mig -> qb;
  mig -> sb;
  cli -> drv;
  cli -> mig;

  // Type-only edges — dashed
  sb  -> drv [style=dashed, label="type"];
  drv -> sb  [style=dashed, label="type"];
}
