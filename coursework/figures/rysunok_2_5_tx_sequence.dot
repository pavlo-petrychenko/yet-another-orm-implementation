digraph tx_sequence {
  rankdir=TB;
  bgcolor="white";
  node [shape=plaintext, fontname="Helvetica", fontsize=10];
  edge [color="#888888", arrowsize=0.6];

  header [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6" BGCOLOR="#eeeeee">
      <TR>
        <TD WIDTH="280"><B>Виклик у коді</B></TD>
        <TD WIDTH="320"><B>SQL у pinned-з'єднанні</B></TD>
      </TR>
    </TABLE>
  >];

  step1 [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
      <TR>
        <TD WIDTH="280" BGCOLOR="#fde7ef" ALIGN="LEFT">ds.transaction(async () =&gt; { … })</TD>
        <TD WIDTH="320" BGCOLOR="#fff5d6" ALIGN="LEFT">BEGIN</TD>
      </TR>
    </TABLE>
  >];

  step2 [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
      <TR>
        <TD WIDTH="280" BGCOLOR="#e7f0ff" ALIGN="LEFT">  await user.save()  <I>// AR</I></TD>
        <TD WIDTH="320" BGCOLOR="#fff5d6" ALIGN="LEFT">INSERT INTO users …</TD>
      </TR>
    </TABLE>
  >];

  step3 [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
      <TR>
        <TD WIDTH="280" BGCOLOR="#fde7ef" ALIGN="LEFT">  await ds.transaction(async () =&gt; { … })</TD>
        <TD WIDTH="320" BGCOLOR="#fff5d6" ALIGN="LEFT">SAVEPOINT sp_1</TD>
      </TR>
    </TABLE>
  >];

  step4 [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
      <TR>
        <TD WIDTH="280" BGCOLOR="#f3e8fd" ALIGN="LEFT">    await postsRepo.save(post)  <I>// Repo</I></TD>
        <TD WIDTH="320" BGCOLOR="#fff5d6" ALIGN="LEFT">INSERT INTO posts …</TD>
      </TR>
    </TABLE>
  >];

  step5 [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
      <TR>
        <TD WIDTH="280" BGCOLOR="#fde7ef" ALIGN="LEFT">  })  <I>// nested success</I></TD>
        <TD WIDTH="320" BGCOLOR="#fff5d6" ALIGN="LEFT">RELEASE SAVEPOINT sp_1</TD>
      </TR>
    </TABLE>
  >];

  step6 [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
      <TR>
        <TD WIDTH="280" BGCOLOR="#f3e8fd" ALIGN="LEFT">  await commentsRepo.save(c)  <I>// Repo</I></TD>
        <TD WIDTH="320" BGCOLOR="#fff5d6" ALIGN="LEFT">INSERT INTO comments …</TD>
      </TR>
    </TABLE>
  >];

  step7 [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
      <TR>
        <TD WIDTH="280" BGCOLOR="#fde7ef" ALIGN="LEFT">})  <I>// outer success</I></TD>
        <TD WIDTH="320" BGCOLOR="#fff5d6" ALIGN="LEFT">COMMIT</TD>
      </TR>
    </TABLE>
  >];

  header -> step1 -> step2 -> step3 -> step4 -> step5 -> step6 -> step7;
}
