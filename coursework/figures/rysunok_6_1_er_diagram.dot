digraph mini_shop_er {
  rankdir=LR;
  graph [splines=polyline, nodesep=0.4, ranksep=0.9];
  node  [shape=plaintext, fontname="Helvetica", fontsize=10];
  edge  [fontname="Helvetica", fontsize=9, arrowsize=0.7];

  User [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD BGCOLOR="#e8eef7" COLSPAN="2"><B>User</B></TD></TR>
      <TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">serial PK</TD></TR>
      <TR><TD ALIGN="LEFT">email</TD><TD ALIGN="LEFT">varchar UNIQUE</TD></TR>
      <TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">varchar</TD></TR>
      <TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
    </TABLE>
  >];

  Product [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD BGCOLOR="#e8eef7" COLSPAN="2"><B>Product</B></TD></TR>
      <TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">serial PK</TD></TR>
      <TR><TD ALIGN="LEFT">sku</TD><TD ALIGN="LEFT">varchar UNIQUE</TD></TR>
      <TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">varchar</TD></TR>
      <TR><TD ALIGN="LEFT">price_cents</TD><TD ALIGN="LEFT">integer</TD></TR>
      <TR><TD ALIGN="LEFT">stock</TD><TD ALIGN="LEFT">integer</TD></TR>
      <TR><TD ALIGN="LEFT">is_active</TD><TD ALIGN="LEFT">boolean</TD></TR>
      <TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
    </TABLE>
  >];

  Order [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD BGCOLOR="#fff3d6" COLSPAN="2"><B>Order</B></TD></TR>
      <TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">serial PK</TD></TR>
      <TR><TD ALIGN="LEFT">user_id</TD><TD ALIGN="LEFT">FK → User</TD></TR>
      <TR><TD ALIGN="LEFT">status</TD><TD ALIGN="LEFT">varchar</TD></TR>
      <TR><TD ALIGN="LEFT">total_cents</TD><TD ALIGN="LEFT">integer</TD></TR>
      <TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamptz</TD></TR>
    </TABLE>
  >];

  OrderItem [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD BGCOLOR="#fff3d6" COLSPAN="2"><B>OrderItem</B></TD></TR>
      <TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">serial PK</TD></TR>
      <TR><TD ALIGN="LEFT">order_id</TD><TD ALIGN="LEFT">FK → Order</TD></TR>
      <TR><TD ALIGN="LEFT">product_id</TD><TD ALIGN="LEFT">FK → Product</TD></TR>
      <TR><TD ALIGN="LEFT">quantity</TD><TD ALIGN="LEFT">integer</TD></TR>
      <TR><TD ALIGN="LEFT">price_at_purchase_cents</TD><TD ALIGN="LEFT">integer</TD></TR>
    </TABLE>
  >];

  User    -> Order     [label="1:N\nON DELETE RESTRICT", arrowhead=crow];
  Order   -> OrderItem [label="1:N\nON DELETE CASCADE",  arrowhead=crow];
  Product -> OrderItem [label="1:N\nON DELETE RESTRICT", arrowhead=crow];
}
