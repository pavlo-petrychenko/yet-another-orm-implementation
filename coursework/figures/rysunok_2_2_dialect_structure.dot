digraph Dialect {
  rankdir=TB;
  bgcolor="white";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, margin="0.14,0.08", color="#333333"];
  edge [color="#666666", arrowsize=0.6];

  dialect [label="PostgresDialect\n(implements Dialect)", fillcolor="#fff3e0", shape=box, style="rounded,filled,bold"];

  // DML branch
  subgraph cluster_dml {
    label="DML: buildQuery(query: Query)";
    fontname="Helvetica"; fontsize=10; style="rounded,dashed"; color="#3a6fb3"; labeljust="l";

    subgraph cluster_dml_top {
      label="Топ-компілятори";
      fontname="Helvetica"; fontsize=9; style="dotted"; color="#9aaedb";
      sel [label="SelectCompiler",  fillcolor="#e7f0ff"];
      ins [label="InsertCompiler",  fillcolor="#e7f0ff"];
      upd [label="UpdateCompiler",  fillcolor="#e7f0ff"];
      del [label="DeleteCompiler",  fillcolor="#e7f0ff"];
    }

    subgraph cluster_dml_sub {
      label="Під-компілятори";
      fontname="Helvetica"; fontsize=9; style="dotted"; color="#9aaedb";
      cnd [label="ConditionCompiler", fillcolor="#dde7f7"];
      jn  [label="JoinCompiler",      fillcolor="#dde7f7"];
      ord [label="OrderByCompiler",   fillcolor="#dde7f7"];
      grp [label="GroupByCompiler",   fillcolor="#dde7f7"];
      lim [label="LimitCompiler",     fillcolor="#dde7f7"];
      off [label="OffsetCompiler",    fillcolor="#dde7f7"];
      ret [label="ReturningCompiler", fillcolor="#dde7f7"];
    }
  }

  // DDL branch
  subgraph cluster_ddl {
    label="DDL: buildDdl(query: DdlQuery)";
    fontname="Helvetica"; fontsize=10; style="rounded,dashed"; color="#7a4ea3"; labeljust="l";

    subgraph cluster_ddl_top {
      label="Топ-компілятори";
      fontname="Helvetica"; fontsize=9; style="dotted"; color="#b294d1";
      crt [label="CreateTableCompiler", fillcolor="#f3e8fd"];
      alt [label="AlterTableCompiler",  fillcolor="#f3e8fd"];
      drp [label="DropTableCompiler",   fillcolor="#f3e8fd"];
      rnm [label="RenameTableCompiler", fillcolor="#f3e8fd"];
    }

    subgraph cluster_ddl_sub {
      label="Під-компілятор";
      fontname="Helvetica"; fontsize=9; style="dotted"; color="#b294d1";
      ct  [label="ColumnTypeCompiler",  fillcolor="#e8d4f5"];
    }
  }

  // Helpers
  subgraph cluster_helpers {
    label="Діалектозалежні помічники";
    fontname="Helvetica"; fontsize=10; style="rounded,dashed"; color="#999999"; labeljust="l";
    pm   [label="PostgresParameterManager\n(implements ParameterManager)", fillcolor="#eef7e8"];
    util [label="PostgresDialectUtils\n(implements DialectUtils)",         fillcolor="#eef7e8"];
  }

  // Dispatch edges
  dialect -> sel; dialect -> ins; dialect -> upd; dialect -> del;
  dialect -> crt; dialect -> alt; dialect -> drp; dialect -> rnm;
  dialect -> pm   [style=dashed, label="createParameterManager()", fontsize=8];
  dialect -> util [style=dashed, label="getUtils()", fontsize=8];

  // Composition: top compilers use sub-compilers (constructor injection)
  sel -> cnd; sel -> jn; sel -> ord; sel -> grp; sel -> lim; sel -> off;
  ins -> ret;
  upd -> cnd; upd -> ret;
  del -> cnd; del -> ret;

  crt -> ct;
  alt -> ct;
}
