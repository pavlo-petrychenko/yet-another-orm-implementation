{
  "name": "@iriskaik/yaoi",
  "version": "1.2.0",
  "description": "YAOI — Yet Another ORM Implementation. A TypeScript ORM for PostgreSQL with decorator-based entities, two-pipeline DML/DDL architecture, and a programmatic migration runner with checksum enforcement.",
  "keywords": [
    "orm",
    "postgres",
    "postgresql",
    "typescript",
    "migrations",
    "decorators",
    "active-record",
    "repository",
    "query-builder",
    "schema-builder"
  ],
  "author": "Pavlo Petrychenko <pavlo.p@mate.academy>",
  "license": "MIT",
  "homepage": "https://github.com/pavlo-petrychenko/yet-another-orm-implementation#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pavlo-petrychenko/yet-another-orm-implementation.git"
  },
  "bugs": {
    "url": "https://github.com/pavlo-petrychenko/yet-another-orm-implementation/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "yaoi": "bin/yaoi.js"
  },
  "files": [
    "dist",
    "bin/yaoi.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "ts-node src/index.ts",
    "cli": "ts-node -r tsconfig-paths/register bin/yaoi.ts",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@types/pg": "^8.11.13",
    "pg": "^8.14.1"
  },
  "peerDependencies": {
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "peerDependenciesMeta": {
    "ts-node": {
      "optional": true
    },
    "tsconfig-paths": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-unused-imports": "^3.2.0",
    "expect-type": "^1.3.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typedoc": "^0.28.3",
    "typescript": "^5.5.3"
  }
}
